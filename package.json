{
  "name": "bethere-server",
  "version": "1.0.0",
  "main": "server.js",
  "type": "module",
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "postinstall": "prisma generate",
    "dev": "node --watch --env-file .env server",
    "migrate": "node --env-file .env ./node_modules/.bin/prisma migrate dev",
    "migrate:deploy": "node --env-file .env ./node_modules/.bin/prisma migrate deploy",
    "start": "node server.js",
    "deploy": "npm install --include=dev && npx prisma generate",
    "seed": "node prisma/seed.js",
    "seed:dev": "node --env-file .env prisma/seed.js",
    "worker:dev": "node --env-file .env worker.js",
    "worker": "node worker.js",
    "studio": "node --env-file .env ./node_modules/.bin/prisma studio",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint ."
  },
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "@napi-rs/canvas": "^0.1.65",
    "@prisma/adapter-pg": "^7.2.0",
    "@prisma/client": "^7.2.0",
    "@sentry/node": "^10.66.0",
    "@tensorflow/tfjs": "^4.22.0",
    "@tensorflow/tfjs-backend-wasm": "^4.22.0",
    "@turf/turf": "^7.2.0",
    "@vladmandic/face-api": "^1.7.15",
    "bcrypt": "^5.1.1",
    "bullmq": "^5.63.0",
    "cloudinary": "^2.8.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "date-fns": "^4.1.0",
    "ejs": "^3.1.10",
    "express": "^4.21.2",
    "express-rate-limit": "^8.5.2",
    "express-validator": "^7.2.1",
    "helmet": "^8.3.0",
    "ioredis": "^5.8.2",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.0.2",
    "nodemailer": "^7.0.10",
    "pg": "^8.16.3",
    "pino": "^10.1.0",
    "pino-http": "^11.0.0",
    "pino-pretty": "^13.1.2",
    "prisma": "^7.2.0",
    "rate-limit-redis": "^6.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.0",
    "@vitest/coverage-v8": "^4.1.10",
    "eslint": "^9.39.0",
    "globals": "^16.5.0",
    "supertest": "^7.2.2",
    "vitest": "^4.1.10"
  }
}
