DATABASE_URL= 'your db url, example "postgresql://postgresUser:password@localhost:5432/dbName?schema=public"'
PORT="your port, example 8080"
NODE_ENV="development"
CORS_ACCESS="your cors access, example 'http://localhost:3000'"
ACCESS_TOKEN_SECRET="your access_token_secret"
REFRESH_TOKEN_SECRET="your_refresh_token_secret"

ADMIN_EMAIL="your admin email, example"
ADMIN_PASSWORD="your admin password, example 1234"
ADMIN_FIRSTNAME="your admin first name, example Nurudeen"
ADMIN_LASTNAME="your admin last name, example Abdul-Majeed"
ADMIN_PHONE="your admin phone number, example 233546488115"


CLOUDINARY_CLOUD_NAME="your cloudinary cloud name"   
CLOUDINARY_API_KEY="your cloudinary api key"    
CLOUDINARY_API_SECRET="your cloudinary api secret"    

REDIS_URL="your redis url"

FRONTEND_URL="your frontend url"

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
GMAIL_USER="the email to senf from"
GMAIL_PASSWORD="gmail app password"
SMTP_SECURE=false
# --- Added by the production-grade overhaul ---
# Venue timezone the "HH:MM" event windows are written in (default Africa/Accra)
# EVENT_TIMEZONE=Africa/Accra
# Explicit opt-in for `npm run seed` (never enable in production)
# ADMIN_SEED_ENABLED=true
# Cookie scope for the httpOnly auth cookies (unset = current host only)
# COOKIE_DOMAIN=.example.com
# Error tracking; unset disables reporting entirely
# SENTRY_DSN=
# Frog (Wigal) SMS credentials for OTP delivery; all unset = log-only SMS
# FROG_API_KEY=
# FROG_USERNAME=
# FROG_SENDER_ID=

# --- Demo login (portfolio) ---
# One-click demo buttons sign into a seeded DEDICATED demo account server-side
# (no credentials in the client, never the real admin). Off by default; enable
# only on the demo deploy, and run the seed so the demo accounts exist.
# DEMO_LOGIN_ENABLED=true
# DEMO_ADMIN_EMAIL=            # defaults to demo-admin@bethere.app (seeded)
# DEMO_ATTENDANT_EMAIL=        # defaults to john.doe@example.com (seeded)

# --- Liveness + biometric compliance ---
# REQUIRED: 32-byte key that encrypts enrolled face templates at rest
# (AES-256-GCM). Generate with: openssl rand -hex 32
# Rotating it invalidates existing templates (users must re-enroll).
FACE_TEMPLATE_ENC_KEY=
# Server-side liveness verification. Default true; set false only for local
# flows/tests that should skip the face models.
# LIVENESS_ENABLED=true
# Directory holding the face-api model weights (shipped in the repo's ./models)
# FACE_MODELS_PATH=./models
# Euclidean match threshold for enrolled vs captured descriptor (default 0.6)
# FACE_MATCH_THRESHOLD=0.6
# Set true on the WEB process when a dedicated worker runs `npm run worker`
# WEB_DISABLE_WORKERS=true
# Docker entrypoint: set to "worker" for the worker container
# PROCESS_TYPE=web
