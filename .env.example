# BeThere API - environment. Copy to .env and fill in the values.
# (required) = the app won't boot without it.
# (optional) = falls back to the noted default when left blank.

# --- Core ---
DATABASE_URL="postgresql://user:pass@localhost:5432/bethere?schema=public"  # (required)
NODE_ENV=development  # (optional) development | production; default development
PORT=8080  # (optional) default 8080

# --- Auth / cookies ---
ACCESS_TOKEN_SECRET=  # (required) long random string
REFRESH_TOKEN_SECRET=  # (required) long random string, different from the access secret
FRONTEND_URL=https://your-frontend.example  # (required) the web app origin; always CORS-allowed
CORS_ACCESS=http://localhost:3000  # (optional) EXTRA allowed origins beyond FRONTEND_URL, comma-separated
COOKIE_DOMAIN=  # (optional) blank = current host only; only set to share auth across subdomains

# --- First admin (created by the seed) ---
ADMIN_EMAIL=  # (required)
ADMIN_PASSWORD=  # (required)
ADMIN_FIRSTNAME=  # (required)
ADMIN_LASTNAME=  # (required)
ADMIN_PHONE=  # (optional) e.g. 233546488115
ADMIN_SEED_ENABLED=  # (optional) true to run `npm run seed`; default false (keep false in prod)
SEED_SAMPLE_DATA=  # (optional) true seeds sample attendants/events too (random passwords); default false - NEVER in prod


# --- Demo login (portfolio) ---
# One-click demo buttons sign into seeded DEDICATED demo accounts, never the real admin.
DEMO_LOGIN_ENABLED=  # (optional) true enables POST /auth/demo-login; default false
DEMO_ADMIN_EMAIL=  # (optional) default demo-admin@bethere.app
DEMO_ATTENDANT_EMAIL=  # (optional) default demo-attendant@bethere.app

# --- Face templates / liveness ---
FACE_TEMPLATE_ENC_KEY=  # (required) 32-byte AES-256-GCM key: `openssl rand -hex 32` (rotating = users re-enroll)
LIVENESS_ENABLED=  # (optional) default true; false skips the face models (local/tests)
FACE_MODELS_PATH=  # (optional) default ./models
FACE_MATCH_THRESHOLD=  # (optional) default 0.6 (euclidean distance)

# --- Media (Cloudinary) ---
CLOUDINARY_CLOUD_NAME=  # (required)
CLOUDINARY_API_KEY=  # (required)
CLOUDINARY_API_SECRET=  # (required)

# --- Redis (sessions, rate limits, job queue) ---
REDIS_URL=redis://localhost:6379  # (required)

# --- Email (SMTP) ---
SMTP_HOST=smtp.gmail.com  # (required)
SMTP_PORT=587  # (optional) default 587
SMTP_SECURE=false  # (optional) default false
GMAIL_USER=  # (required) the account outgoing mail is sent from
GMAIL_PASSWORD=  # (required) app password
SMTP_MAIL=  # (optional) from-address; default = GMAIL_USER

# --- SMS OTP (Frog / Wigal) ---
# All three blank = log-only SMS (codes go to the logs, not sent).
FROG_API_KEY=  # (optional)
FROG_USERNAME=  # (optional)
FROG_SENDER_ID=  # (optional)

# --- Ops ---
EVENT_TIMEZONE=Africa/Accra  # (optional) tz for the "HH:MM" event windows; default Africa/Accra
SENTRY_DSN=  # (optional) error tracking; blank disables
WEB_DISABLE_WORKERS=  # (optional) true on the web process when a separate `npm run worker` runs; default false
PROCESS_TYPE=web  # (optional) Docker entrypoint: web | worker
TRUST_PROXY=1  # (optional) Express trust proxy: hop count, true, or false when exposed directly (no LB); default 1
WORKER_HEALTH_PORT=8081  # (optional) worker process's /health port for the Docker HEALTHCHECK; 0 disables; default 8081
LOG_LEVEL=  # (optional) pino level override; defaults: info (prod), debug (dev), silent (test)
