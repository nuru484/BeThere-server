generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// Staff principal, separate from attendants: different lifecycle, no
// attendance or biometrics. Ids overlap with User ids, so tokens and
// security rows always carry a `kind` alongside the id.
model Admin {
  id             Int     @id @default(autoincrement())
  firstName      String  @db.VarChar(255)
  lastName       String  @db.VarChar(255)
  password       String
  email          String  @unique
  profilePicture String? @db.VarChar(255)
  phone          String? @unique

  twoFactorEnabled Boolean @default(false)

  tokenVersion Int       @default(0)
  deletedAt    DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([deletedAt])
}

// Hashed single-use codes for OTP login (attendants) and the 2FA second
// factor (both principals). Modeled on PasswordReset: sha256 code hash,
// short TTL, attempt cap, consumed-at.
model OtpCode {
  id          Int       @id @default(autoincrement())
  kind        String // "ADMIN" | "USER"
  principalId Int
  purpose     String // "LOGIN" | "TWO_FACTOR"
  channel     String // "SMS" | "EMAIL"
  codeHash    String
  expiresAt   DateTime
  consumedAt  DateTime?
  attempts    Int       @default(0)

  createdAt DateTime @default(now())

  @@index([kind, principalId, purpose])
  @@index([expiresAt])
}

model User {
  id                      Int       @id @default(autoincrement())
  firstName               String    @db.VarChar(255)
  lastName                String    @db.VarChar(255)
  // Nullable: admin-created attendants start passwordless and sign in via
  // OTP; a password only exists if the user sets one (e.g. via reset flow).
  password                String?
  email                   String    @unique
  profilePicture          String?   @db.VarChar(255)
  phone                   String?   @unique
  // Legacy plaintext descriptor. Superseded by faceScanEnc (encrypted at
  // rest); kept nullable during the expand/backfill window and read only as a
  // fallback. A later migration drops it once every row is encrypted.
  faceScan                Json?
  // The enrolled 128-float template, AES-256-GCM encrypted (base64 iv:tag:ct).
  // Biometric data is decrypted in memory only at match time and never leaves
  // the server.
  faceScanEnc             String?
  // Biometric consent (GDPR Art. 9 / BIPA): enrollment is refused without it.
  // The version lets a policy change force re-consent.
  biometricConsentAt      DateTime?
  biometricConsentVersion String?
  // Last time the template verified a check-in; drives retention purge of
  // dormant biometrics.
  faceLastUsedAt          DateTime?

  twoFactorEnabled Boolean @default(false)
  /**
   * Set once the phone has received and confirmed an OTP.
   */
  phoneVerified    Boolean @default(false)

  // Session epoch: bumped on refresh-token theft detection or forced logout,
  // which invalidates every outstanding token minted before the bump.
  tokenVersion Int @default(0)

  // Soft delete: reads scope to deletedAt IS NULL via the prisma extension;
  // history (attendance) survives account removal.
  deletedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  Attendance Attendance[]

  // Intentional indexes only: id/email/phone were redundant (PK and @unique
  // already index). deletedAt supports the soft-delete scoping every read
  // now carries.
  @@index([deletedAt])
}

// One row per outstanding refresh token (hashed jti). Rotation consumes the
// row and issues a successor; presenting a consumed jti again is treated as
// theft and bumps the user's tokenVersion, killing every live session.
model RefreshToken {
  id          Int       @id @default(autoincrement())
  kind        String // "ADMIN" | "USER"
  principalId Int
  jtiHash     String    @unique
  expiresAt   DateTime
  consumedAt  DateTime?
  // Stamped the first time an already-consumed token is honoured under the
  // rotation-race leeway. Bounds that leeway to ONE re-issue, so a genuine
  // two-tab race still works while a token replayed repeatedly inside the
  // window is caught as theft instead of minting a session each time.
  reusedAt    DateTime?

  createdAt DateTime @default(now())

  @@index([kind, principalId])
  @@index([expiresAt])
}

model PasswordReset {
  id          Int       @id @default(autoincrement())
  kind        String // "ADMIN" | "USER"
  principalId Int
  tokenHash   String    @unique
  expiresAt   DateTime
  usedAt      DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([kind, principalId])
  @@index([expiresAt])
}

model Event {
  id                 Int       @id @default(autoincrement())
  title              String
  description        String?
  startDate          DateTime // First occurrence start date
  endDate            DateTime? // Optional: when the occurrences end
  isRecurring        Boolean   @default(false)
  recurrenceInterval Int       @default(1) // Every X days/weeks (e.g., 3 for every 3 days)
  durationDays       Int       @default(1) // How many days each occurrence lasts
  startTime          String // When attendance opens (e.g., "06:00")
  endTime            String // When attendance closes (e.g., "19:30")
  archived           Boolean   @default(false) // Archive status
  coverImage         String?   @db.VarChar(255) // Cloudinary secure URL
  // Per-event secret for the rotating venue code (proof of on-site presence).
  // The 30s codes shown on the venue display are keyed HMACs of this secret +
  // the time window; the secret itself never leaves the server. Nullable so
  // pre-existing events lazily gain one on first use.
  venueSecret        String?

  // Soft delete: removed events disappear from lists but their sessions and
  // attendance history stay queryable for reports.
  deletedAt DateTime?

  location   Location @relation(fields: [locationId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  locationId Int
  type       String

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  sessions  Session[]

  // The list surface filters on archive state and orders by start date; the
  // scheduler scans by recurrence; every read scopes deletedAt.
  @@index([deletedAt])
  @@index([archived, startDate])
  @@index([isRecurring])
  @@index([locationId])
}

model Session {
  id        Int      @id @default(autoincrement())
  eventId   Int
  startDate DateTime
  endDate   DateTime
  startTime DateTime
  endTime   DateTime

  // Stamped by the session-finalizer job once the day's window (plus grace)
  // has closed: ABSENT rows are written and open attendances auto-checked-out
  // exactly once per session. Null = not yet finalized.
  finalizedAt DateTime?

  event       Event        @relation(fields: [eventId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  attendances Attendance[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([eventId, startDate])
  // Check-in resolves "the active session today" by date window.
  @@index([startDate, endDate])
  // The finalizer sweeps for finalizedAt IS NULL on past days.
  @@index([finalizedAt])
}

model Location {
  id        Int     @id @default(autoincrement())
  name      String
  city      String?
  country   String?
  events    Event[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([name])
}

enum AttendanceStatus {
  PRESENT
  LATE
  ABSENT
}

model Attendance {
  id           Int              @id @default(autoincrement())
  status       AttendanceStatus @default(ABSENT)
  userId       Int
  sessionId    Int
  // Nullable: ABSENT rows written by the session finalizer have no check-in.
  checkInTime  DateTime?
  checkOutTime DateTime?
  // True when the finalizer stamped the check-out (user never signed out);
  // distinguishes an administrative close from a real face-verified check-out.
  autoCheckedOut Boolean @default(false)

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, sessionId])
  // Every report/list orders or filters by check-in time, and the session
  // relation is joined constantly - both were unindexed.
  @@index([checkInTime])
  @@index([sessionId])
}

// A server-issued liveness challenge for one check-in attempt. The randomized
// action sequence is the anti-replay mechanism: a pre-recorded capture cannot
// satisfy actions the client learned only after the server picked them. The
// signed token the client returns carries the nonce; exchanging it consumes
// this row (atomic updateMany, like the refresh/OTP flows).
model LivenessChallenge {
  id         Int       @id @default(autoincrement())
  userId     Int
  // Null for ENROLLMENT challenges, which prove liveness before a template
  // exists and therefore belong to no event.
  eventId    Int?
  nonce      String    @unique
  // Ordered action codes, e.g. ["TURN_LEFT", "BLINK", "SMILE"].
  actions    Json
  // Step-by-step flow: the index of the next action to prove (0..actions.length).
  // The batch flow never advances it. Advanced atomically per verified step.
  currentStep Int      @default(0)
  // Encrypted (owner-bound, AES-256-GCM) cross-step state for the step-by-step
  // flow: the per-step medoid descriptors gathered so far and the first turn's
  // sign. Null for batch challenges. Biometrics never sit here in plaintext, and
  // the row is short-lived (deleted on consume / by the retention sweep).
  stateEnc   String?
  expiresAt  DateTime
  consumedAt DateTime?

  createdAt DateTime @default(now())

  @@index([userId, eventId])
  @@index([expiresAt])
}

enum PairingScope {
  ATTENDANCE
  ENROLL
}

enum PairingStatus {
  PENDING
  COMPLETED
  EXPIRED
}

// Cross-device "scan from phone" hand-off. A laptop (cookie-authenticated)
// starts a pairing; the phone opens a QR-deep-link carrying a short-lived signed
// hand-off token scoped to ONLY this capture, does the scan, and marks the
// session COMPLETED. The laptop polls the row to learn it finished. The token is
// never a full session - it works only on the /pairing capture endpoints.
model PairingSession {
  id          String        @id @default(uuid())
  userId      Int
  scope       PairingScope
  // The event to check in/out of (ATTENDANCE only; null for ENROLL).
  eventId     Int?
  // "in" | "out" for attendance, "enroll" for enrollment.
  mode        String        @default("in")
  status      PairingStatus @default(PENDING)
  expiresAt   DateTime
  completedAt DateTime?

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}

enum AnomalyType {
  DUPLICATE_DESCRIPTOR
  LIVENESS_FAILED
  REPLAY_SUSPECTED
  RAPID_ATTEMPTS
}

enum AnomalySeverity {
  LOW
  MEDIUM
  HIGH
}

// Detective control (not preventive): a reviewable signal that a check-in
// attempt looked wrong. Recorded whether or not the attempt was allowed, so a
// manager has an audit trail. FK-less (references either principal table by
// kind, like the security rows above).
model AnomalyFlag {
  id         Int             @id @default(autoincrement())
  userId     Int
  eventId    Int?
  type       AnomalyType
  severity   AnomalySeverity @default(MEDIUM)
  detail     Json?
  // The evidence, if any frames were retained for this flag.
  evidenceId Int?
  resolvedAt DateTime?

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([type])
  @@index([createdAt])
  @@index([resolvedAt])
}

// Captured frames retained ONLY for a flagged/anomalous attempt (data
// minimization). Stored on Cloudinary; expiresAt drives the retention purge.
model AttendanceEvidence {
  id            Int      @id @default(autoincrement())
  userId        Int
  eventId       Int
  attendanceId  Int?
  frameUrls     Json
  livenessScore Float?
  matchDistance Float?
  reason        String?
  expiresAt     DateTime

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}

// Immutable-by-convention audit trail for check-ins and admin actions. FK-less
// polymorphic actor (kind + id), no updatedAt (append-only).
model AuditLog {
  id         Int     @id @default(autoincrement())
  actorKind  String // "ADMIN" | "USER" | "SYSTEM"
  actorId    Int?
  action     String
  targetType String?
  targetId   Int?
  metadata   Json?
  ip         String?

  createdAt DateTime @default(now())

  @@index([actorKind, actorId])
  @@index([action])
  @@index([createdAt])
}
